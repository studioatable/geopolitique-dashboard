# ============================================================================
# Variables d'environnement — geopolitique-dashboard
# ============================================================================
# Copier ce fichier en .env (à la racine) et renseigner les valeurs réelles.
# Le fichier .env ne doit JAMAIS être committé (déjà dans .gitignore).
# Sur GitHub, ces variables sont stockées dans Settings > Secrets and variables > Actions.
# Sur o2switch, elles sont chargées par le wrapper shell qui lance les scripts cron.
# ============================================================================

# --- ACLED — Conflits (étape 9 de la roadmap) ---
# Demande de clé gratuite : https://acleddata.com/register/
ACLED_API_KEY=
ACLED_EMAIL=

# --- EIA — Énergie (non utilisé en v1.0, prévu v2) ---
# Demande de clé gratuite : https://www.eia.gov/opendata/register.php
# EIA_API_KEY=

# --- GeoNames — Toponymes (non utilisé en v1.0, prévu v2) ---
# Inscription : https://www.geonames.org/login
# GEONAMES_USERNAME=

# --- Configuration générale ---
# Niveau de log : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Dossier de sortie des données normalisées (par défaut : ./data)
DATA_OUTPUT_DIR=./data

# User-Agent à présenter aux serveurs distants
USER_AGENT=Studio-a-Table-Geopolitique-Dashboard/0.1.0 (+https://studioatable.fr)
